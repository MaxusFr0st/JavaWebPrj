# Copy to .env for local docker-compose, or set these in Railway → Variables.
# Never commit real values.

SPRING_PROFILES_ACTIVE=prod

# Railway sets PORT and DATABASE_URL automatically when PostgreSQL is linked.
# Optional explicit JDBC (overrides DATABASE_URL parsing):
# SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/railway
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

# First deploy only: create tables, then switch to validate
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Required in production (openssl rand -base64 48)
APP_JWT_SECRET=

# Optional: create admin on first boot (min 12 chars)
APP_SEED_ADMIN_PASSWORD=
APP_SEED_ADMIN_USERNAME=admin
APP_SEED_ADMIN_EMAIL=admin@yourdomain.com

# PayPal sandbox or live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_CURRENCY=EUR

# Demo catalog seed (products) — safe for prod demo shop
APP_SEED_CATALOG=true
APP_SEED_USERS=false
